    "mysql2": "^3.16.1",
    "next": "^16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.12",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.70.0",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0",
